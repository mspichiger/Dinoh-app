{
    "name": "dinoh-backend",
    "version": "0.1.0",
    "private": true,
    "description": "Backend API for the DINOH Digital Innovation Hub",
    "main": "dist/server.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/server.js",
        "lint": "tsc --noEmit"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^5.1.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.1",
        "@types/node": "^20.17.19",
        "ts-node-dev": "^2.0.0",
        "typescript": "~5.9.2"
    }
}